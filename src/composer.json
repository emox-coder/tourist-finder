{
    "name": "taf/tourist-attraction-finder",
    "description": "Tourist Attraction Finder Web Application",
    "type": "project",
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "doctrine/instantiator": "^1.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "Backend/app/",
            "Infrastructure\\": "Backend/Infrastructure/"
        }
    },
    "scripts": {
        "test": "phpunit --configuration phpunit.xml"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}